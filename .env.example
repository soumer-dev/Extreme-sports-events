RESEND_API_KEY=
# The "from" address — must be on a domain verified in your Resend account.
# Example: reservations@extremesportsevents.ma
# Falls back to onboarding@resend.dev (only works when sending to the Resend account owner).
RESEND_FROM_EMAIL=
# Single recipient:   RECIPIENT_EMAIL=you@example.com
# Multiple recipients (comma or semicolon separated):
#   RECIPIENT_EMAIL=you@example.com,team@example.com,admin@example.com
RECIPIENT_EMAIL=
APP_URL=

# Google Tag Manager (GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

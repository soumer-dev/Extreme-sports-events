RESEND_API_KEY=
# Single recipient:   RECIPIENT_EMAIL=you@yourdomain.com
# Multiple recipients (comma or semicolon separated):
#   RECIPIENT_EMAIL=you@yourdomain.com,team@yourdomain.com
# IMPORTANT: put your Resend-verified domain address LAST — it is used as the sender.
RECIPIENT_EMAIL=
APP_URL=

# Google Tag Manager (GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
